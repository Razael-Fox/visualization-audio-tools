# API Key for Gemini (used for AI Insights across all tools)
# Get it from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# API Key for Groq (used for ultra-fast Whisper Speech-to-Text)
# Get it from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Supabase Configuration (used for Usage Limits and GitHub Login)
# Get it from your Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
